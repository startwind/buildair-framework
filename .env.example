# Database
DB_ROOT_PASSWORD=rootpassword
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=app_password

# Symfony
APP_SECRET=change_me_in_production_32chars_!!
JWT_PASSPHRASE=jwt_passphrase_change_me

# Mailer — use null://null to disable, or e.g. smtp://user:pass@smtp.example.com:587
MAILER_DSN=null://null

# Double-Opt-In: set to true to require email verification after registration
DOUBLE_OPT_IN=false

# URLs
APP_URL=http://localhost:4000
FROM_EMAIL=noreply@example.com
NUXT_PUBLIC_API_BASE=http://localhost:8000
